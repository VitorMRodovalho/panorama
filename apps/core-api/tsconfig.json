{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2022",
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "types": ["node", "multer"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "prisma/seed.ts"],
  "exclude": ["node_modules", "dist"]
}
