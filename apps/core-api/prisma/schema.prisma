// Panorama core schema — initial draft.
//
// Multi-tenancy notes (see ADR-0003):
//   * Every tenant-owned model has `tenantId` and is filtered by Prisma
//     middleware. The middleware adds `WHERE tenant_id = current` to every
//     query unless the caller is in cross-tenant scope.
//   * Postgres Row-Level Security policies duplicate the predicate at the DB
//     layer, keyed on `app.current_tenant` session GUC. RLS policies are
//     defined in SQL migrations (Prisma can't model them natively).
//   * `users` and `auth_identities` are global; per-tenant membership lives
//     in `tenant_memberships`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: the multi-schema preview is deliberately not enabled yet. Once we
// introduce genuinely cross-schema tables (e.g., cluster-wide config that
// operators shouldn't touch with normal migrations), we'll flip
// previewFeatures = ["multiSchema"] and move SystemSetting to
// `panorama_system`. For the 0.1 scaffold, everything lives in `public` so
// migrations stay simple.

// -----------------------------------------------------------------------------
// Global (non-tenant) entities
// -----------------------------------------------------------------------------

model Tenant {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @unique
  name        String
  displayName String
  locale      String    @default("en")
  timezone    String    @default("UTC")
  /// Email domains this tenant claims. A user signing in with an email
  /// matching any domain here is auto-routed to this tenant during
  /// home-realm discovery and eligible for just-in-time membership.
  /// **Community edition does NOT verify domain ownership** — anyone can
  /// claim a domain. Enterprise adds DNS TXT verification so a tenant
  /// cannot intercept users from a domain it does not control.
  allowedEmailDomains String[] @default([])
  /// Default TTL applied when an admin creates a new invitation, in
  /// seconds. Community caps between 3 600 (1 h) and 2 592 000 (30 d).
  /// See ADR-0008.
  invitationTtlSeconds Int      @default(604800)
  /// Per-tenant reservation policy — see ADR-0009. Shape:
  /// {
  ///   "min_notice_hours": 0,
  ///   "max_duration_hours": 0,
  ///   "max_concurrent_per_user": 0,
  ///   "auto_approve_roles": ["owner", "fleet_admin", "fleet_staff"]
  /// }
  /// Zero means "not enforced" for each numeric.
  reservationRules Json @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  memberships TenantMembership[]
  assets      Asset[]
  categories  Category[]
  invitations Invitation[]
  blackouts   BlackoutSlot[]

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.Citext
  displayName  String
  firstName    String?
  lastName     String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  lastLoginAt  DateTime?

  authIdentities AuthIdentity[]
  memberships    TenantMembership[]
  invitationsSent    Invitation[] @relation("InvitationInviter")
  invitationsTargeted Invitation[] @relation("InvitationTarget")
  invitationsAccepted Invitation[] @relation("InvitationAcceptor")
  invitationsRevoked  Invitation[] @relation("InvitationRevoker")
  reservationsRequested Reservation[] @relation("ReservationRequester")
  reservationsOnBehalf  Reservation[] @relation("ReservationOnBehalf")
  reservationsApproved  Reservation[] @relation("ReservationApprover")
  reservationsCancelled Reservation[] @relation("ReservationCanceller")
  blackoutsCreated      BlackoutSlot[]

  @@map("users")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED

  @@map("user_status")
}

model AuthIdentity {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  /// 'password' | 'google' | 'microsoft' | 'saml' | 'webauthn'
  provider     String
  /// For password: userId (self-referential). For OIDC/SAML: the IdP's sub claim.
  subject      String
  emailAtLink  String
  /// Argon2id hash for the 'password' provider. NULL for every other provider.
  /// Never exposed via the API surface.
  secretHash   String?
  attributes   Json?
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, subject])
  @@index([userId])
  @@map("auth_identities")
}

// -----------------------------------------------------------------------------
// Tenancy membership — joins global users to tenants
// -----------------------------------------------------------------------------

model TenantMembership {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @db.Uuid
  userId             String   @db.Uuid
  /// 'super_admin' | 'fleet_admin' | 'fleet_staff' | 'driver' | custom
  role               String
  /// 'active' — user can use this tenant. 'invited' — pending acceptance,
  /// no access until first login with email match or explicit acceptance.
  /// 'suspended' — access revoked, membership preserved for audit.
  status             String   @default("active")
  isVip              Boolean  @default(false)
  trainingValidUntil DateTime?
  /// Invitation trail — populated when a membership is created by an
  /// admin before the target user has authenticated into Panorama.
  invitedByUserId    String?  @db.Uuid
  invitedAt          DateTime?
  acceptedAt         DateTime?
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, status])
  @@map("tenant_memberships")
}

// -----------------------------------------------------------------------------
// Invitations — email-token one-time-use onboarding (ADR-0008)
// -----------------------------------------------------------------------------

model Invitation {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  /// Lowercased + trimmed at write time. Citext so lookups are
  /// case-insensitive without calling lower() at every query site.
  email            String   @db.Citext
  /// 'owner' | 'fleet_admin' | 'fleet_staff' | 'driver' | custom
  role             String
  /// SHA-256(token) base64url. Plaintext lives only in the email + URL.
  /// Unique so a pathological collision becomes a constraint violation
  /// instead of a silent account takeover (defence in depth at 256-bit).
  tokenHash        String   @unique
  /// Pre-existing Panorama User the admin is re-inviting; NULL when the
  /// target has no account yet.
  targetUserId     String?  @db.Uuid
  invitedByUserId  String   @db.Uuid
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?  @db.Uuid
  revokedAt        DateTime?
  revokedByUserId  String?  @db.Uuid
  /// Outbox state mirrored from the email delivery pipeline. See ADR-0008.
  /// `emailAttempts` counts worker attempts (covered by the ADR's
  /// "up to 5 attempts" retry policy — persisted here for observability
  /// and so retries survive worker restarts).
  emailQueuedAt    DateTime?
  emailSentAt      DateTime?
  emailBouncedAt   DateTime?
  emailAttempts    Int      @default(0)
  emailLastError   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy        User     @relation("InvitationInviter",  fields: [invitedByUserId],   references: [id])
  targetUser       User?    @relation("InvitationTarget",   fields: [targetUserId],      references: [id], onDelete: SetNull)
  acceptedBy       User?    @relation("InvitationAcceptor", fields: [acceptedByUserId],  references: [id], onDelete: SetNull)
  revokedBy        User?    @relation("InvitationRevoker",  fields: [revokedByUserId],   references: [id], onDelete: SetNull)

  /// A partial unique index enforces "at most one open invite per
  /// (tenantId, email)" — written as raw SQL in the migration because
  /// Prisma cannot model partial indexes.
  @@index([tenantId, email])
  @@index([expiresAt])
  @@map("invitations")
}

// -----------------------------------------------------------------------------
// Tenant-owned catalog primitives
// -----------------------------------------------------------------------------

model Category {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @db.Uuid
  name      String
  kind      CategoryKind
  eula      String?
  checkoutAccepted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  models    AssetModel[]

  @@unique([tenantId, name, kind])
  @@index([tenantId])
  @@map("categories")
}

enum CategoryKind {
  HARDWARE
  LICENSE
  ACCESSORY
  CONSUMABLE
  COMPONENT
  VEHICLE
  OTHER

  @@map("category_kind")
}

model Manufacturer {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @db.Uuid
  name      String
  url       String?
  supportEmail String?
  supportPhone String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models    AssetModel[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("manufacturers")
}

model AssetModel {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  categoryId     String   @db.Uuid
  manufacturerId String?  @db.Uuid
  name           String
  modelNumber    String?
  imageUrl       String?
  fieldsetId     String?  @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category       Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  assets         Asset[]

  @@index([tenantId])
  @@index([categoryId])
  @@map("asset_models")
}

// -----------------------------------------------------------------------------
// Asset — unified across hardware, vehicles, licenses, etc.
// -----------------------------------------------------------------------------

model Asset {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  modelId        String   @db.Uuid
  tag            String
  name           String
  serial         String?
  status         AssetStatus @default(READY)
  bookable       Boolean  @default(false)
  locationId     String?  @db.Uuid
  assignedUserId String?  @db.Uuid
  customFields   Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  archivedAt     DateTime?

  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  model          AssetModel @relation(fields: [modelId], references: [id], onDelete: Restrict)
  reservations   Reservation[]

  @@unique([tenantId, tag])
  @@index([tenantId, status])
  @@index([tenantId, bookable])
  @@map("assets")
}

enum AssetStatus {
  READY
  IN_USE
  RESERVED
  MAINTENANCE
  RETIRED

  @@map("asset_status")
}

// -----------------------------------------------------------------------------
// Reservations + approvals (from FleetManager)
// -----------------------------------------------------------------------------

model Reservation {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  assetId         String?  @db.Uuid
  requesterUserId String   @db.Uuid
  onBehalfUserId  String?  @db.Uuid
  startAt         DateTime
  endAt           DateTime
  purpose         String?
  approvalStatus  ApprovalStatus @default(PENDING_APPROVAL)
  lifecycleStatus ReservationStatus @default(BOOKED)
  /// Approval trail — populated when an admin approves or rejects.
  approverUserId  String?  @db.Uuid
  approvedAt      DateTime?
  approvalNote    String?
  /// Cancellation trail (applies whether requester or admin cancels).
  cancelReason    String?
  cancelledAt     DateTime?
  cancelledByUserId String? @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  asset           Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  requester       User     @relation("ReservationRequester", fields: [requesterUserId], references: [id])
  onBehalf        User?    @relation("ReservationOnBehalf",  fields: [onBehalfUserId],  references: [id])
  approver        User?    @relation("ReservationApprover",  fields: [approverUserId],  references: [id], onDelete: SetNull)
  canceller       User?    @relation("ReservationCanceller", fields: [cancelledByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, startAt])
  @@index([tenantId, approvalStatus])
  @@index([tenantId, assetId])
  @@index([tenantId, requesterUserId])
  @@index([tenantId, lifecycleStatus])
  @@map("reservations")
}

model BlackoutSlot {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  /// NULL = applies to all assets in the tenant (global maintenance
  /// window, holiday, etc.). Non-null = scoped to that asset.
  assetId         String?  @db.Uuid
  title           String
  startAt         DateTime
  endAt           DateTime
  reason          String?
  createdByUserId String   @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User     @relation(fields: [createdByUserId], references: [id])

  @@index([tenantId, startAt])
  @@index([tenantId, assetId])
  @@map("blackout_slots")
}

enum ApprovalStatus {
  PENDING_APPROVAL
  AUTO_APPROVED
  APPROVED
  REJECTED

  @@map("approval_status")
}

enum ReservationStatus {
  BOOKED
  CHECKED_OUT
  RETURNED
  CANCELLED
  MISSED
  MAINTENANCE_REQUIRED
  REDIRECTED

  @@map("reservation_status")
}

// -----------------------------------------------------------------------------
// Audit log — hash-chained, append-only
// -----------------------------------------------------------------------------

model AuditEvent {
  id             BigInt   @id @default(autoincrement())
  tenantId       String?  @db.Uuid
  actorUserId    String?  @db.Uuid
  action         String
  resourceType   String
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  occurredAt     DateTime @default(now())
  prevHash       Bytes?
  selfHash       Bytes

  @@index([tenantId, occurredAt(sort: Desc)])
  @@map("audit_events")
}

// -----------------------------------------------------------------------------
// System (global) — feature flags, cluster-level config
// -----------------------------------------------------------------------------

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

/// Tracks (source system, entity, source id) → Panorama UUID for migration
/// idempotency. Populated by @panorama/migrator's `migrate` command output
/// and consumed by the core-api's ImportService. Not tenant-scoped —
/// migrations are super-admin operations.
model ImportIdentityMap {
  id         BigInt   @id @default(autoincrement())
  source     String
  entity     String
  sourceId   String
  panoramaId String   @db.Uuid
  tenantId   String?  @db.Uuid
  createdAt  DateTime @default(now())

  @@unique([source, entity, sourceId])
  @@index([source, entity, panoramaId])
  @@map("import_identity_map")
}
