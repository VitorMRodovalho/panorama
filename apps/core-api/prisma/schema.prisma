// Panorama core schema — initial draft.
//
// Multi-tenancy notes (see ADR-0003):
//   * Every tenant-owned model has `tenantId` and is filtered by Prisma
//     middleware. The middleware adds `WHERE tenant_id = current` to every
//     query unless the caller is in cross-tenant scope.
//   * Postgres Row-Level Security policies duplicate the predicate at the DB
//     layer, keyed on `panorama.current_tenant` session GUC (renamed from
//     `app.current_tenant` in migration 0013 per ADR-0015 v2). RLS policies
//     are defined in SQL migrations (Prisma can't model them natively).
//   * `users` and `auth_identities` are global; per-tenant membership lives
//     in `tenant_memberships`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: the multi-schema preview is deliberately not enabled yet. Once we
// introduce genuinely cross-schema tables (e.g., cluster-wide config that
// operators shouldn't touch with normal migrations), we'll flip
// previewFeatures = ["multiSchema"] and move SystemSetting to
// `panorama_system`. For the 0.1 scaffold, everything lives in `public` so
// migrations stay simple.

// -----------------------------------------------------------------------------
// Global (non-tenant) entities
// -----------------------------------------------------------------------------

model Tenant {
  id                              String    @id @default(uuid()) @db.Uuid
  slug                            String    @unique
  name                            String
  displayName                     String
  locale                          String    @default("en")
  timezone                        String    @default("UTC")
  /// Email domains this tenant claims. A user signing in with an email
  /// matching any domain here is auto-routed to this tenant during
  /// home-realm discovery and eligible for just-in-time membership.
  /// **Community edition does NOT verify domain ownership** — anyone can
  /// claim a domain. Enterprise adds DNS TXT verification so a tenant
  /// cannot intercept users from a domain it does not control.
  allowedEmailDomains             String[]  @default([])
  /// Default TTL applied when an admin creates a new invitation, in
  /// seconds. Community caps between 3 600 (1 h) and 2 592 000 (30 d).
  /// See ADR-0008.
  invitationTtlSeconds            Int       @default(604800)
  /// Per-tenant reservation policy — see ADR-0009. Shape:
  /// {
  ///   "min_notice_hours": 0,
  ///   "max_duration_hours": 0,
  ///   "max_concurrent_per_user": 0,
  ///   "auto_approve_roles": ["owner", "fleet_admin", "fleet_staff"]
  /// }
  /// Zero means "not enforced" for each numeric.
  reservationRules                Json      @default("{}")
  /// Retention override (days) for notification_events.status=DISPATCHED
  /// rows owned by this tenant. Null → default-fallback 90 d. ADR-0011.
  notificationRetentionDays       Int?
  /// Per-tenant inspection policy (ADR-0012). Null = defaults.
  /// Zod-validated shape: { maxPhotosPerInspection, maxPhotoBytes,
  /// maxPhotoDimension, staleInProgressHours,
  /// preCheckoutInspectionMaxAgeMinutes }. Community ships the
  /// column + defaults; Enterprise gates the per-tenant override UI.
  inspectionConfig                Json?
  /// Photo retention override (days). Null = default 425 (DOT 49 CFR
  /// §396.3 14-mo floor + 2-mo buffer). Service-layer floor 30.
  inspectionPhotoRetentionDays    Int?
  /// Reservation tether (ADR-0012 §8). When true, checkOut rejects
  /// 409 `inspection_required` unless a COMPLETED+PASS inspection
  /// exists for (asset, user) within the config window. Default off.
  requireInspectionBeforeCheckout Boolean   @default(false)
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt
  deletedAt                       DateTime?

  memberships             TenantMembership[]
  assets                  Asset[]
  categories              Category[]
  invitations             Invitation[]
  blackouts               BlackoutSlot[]
  personalAccessTokens    PersonalAccessToken[]
  notificationEvents      NotificationEvent[]
  inspectionTemplates     InspectionTemplate[]
  inspectionTemplateItems InspectionTemplateItem[]
  inspections             Inspection[]
  inspectionResponses     InspectionResponse[]
  inspectionPhotos        InspectionPhoto[]

  @@map("tenants")
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  email       String     @unique @db.Citext
  displayName String
  firstName   String?
  lastName    String?
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  lastLoginAt DateTime?

  authIdentities             AuthIdentity[]
  memberships                TenantMembership[]
  invitationsSent            Invitation[]          @relation("InvitationInviter")
  invitationsTargeted        Invitation[]          @relation("InvitationTarget")
  invitationsAccepted        Invitation[]          @relation("InvitationAcceptor")
  invitationsRevoked         Invitation[]          @relation("InvitationRevoker")
  reservationsRequested      Reservation[]         @relation("ReservationRequester")
  reservationsOnBehalf       Reservation[]         @relation("ReservationOnBehalf")
  reservationsApproved       Reservation[]         @relation("ReservationApprover")
  reservationsCancelled      Reservation[]         @relation("ReservationCanceller")
  reservationsCheckedOut     Reservation[]         @relation("ReservationCheckedOutBy")
  reservationsCheckedIn      Reservation[]         @relation("ReservationCheckedInBy")
  blackoutsCreated           BlackoutSlot[]
  personalAccessTokens       PersonalAccessToken[] @relation("OwnedTokens")
  issuedAccessTokens         PersonalAccessToken[] @relation("IssuedTokens")
  inspectionTemplatesCreated InspectionTemplate[]  @relation("InspectionTemplateCreator")
  inspectionsStarted         Inspection[]          @relation("InspectionStarter")
  inspectionsCompleted       Inspection[]          @relation("InspectionCompleter")
  inspectionsReviewed        Inspection[]          @relation("InspectionReviewer")
  inspectionPhotosUploaded   InspectionPhoto[]     @relation("InspectionPhotoUploader")

  @@map("users")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED

  @@map("user_status")
}

model AuthIdentity {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  /// 'password' | 'google' | 'microsoft' | 'saml' | 'webauthn'
  provider    String
  /// For password: userId (self-referential). For OIDC/SAML: the IdP's sub claim.
  subject     String
  emailAtLink String
  /// Argon2id hash for the 'password' provider. NULL for every other provider.
  /// Never exposed via the API surface.
  secretHash  String?
  attributes  Json?
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, subject])
  @@index([userId])
  @@map("auth_identities")
}

// -----------------------------------------------------------------------------
// Tenancy membership — joins global users to tenants
// -----------------------------------------------------------------------------

model TenantMembership {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @db.Uuid
  userId             String    @db.Uuid
  /// 'super_admin' | 'fleet_admin' | 'fleet_staff' | 'driver' | custom
  role               String
  /// 'active' — user can use this tenant. 'invited' — pending acceptance,
  /// no access until first login with email match or explicit acceptance.
  /// 'suspended' — access revoked, membership preserved for audit.
  status             String    @default("active")
  isVip              Boolean   @default(false)
  trainingValidUntil DateTime?
  /// Invitation trail — populated when a membership is created by an
  /// admin before the target user has authenticated into Panorama.
  invitedByUserId    String?   @db.Uuid
  invitedAt          DateTime?
  acceptedAt         DateTime?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, status])
  @@map("tenant_memberships")
}

// -----------------------------------------------------------------------------
// Invitations — email-token one-time-use onboarding (ADR-0008)
// -----------------------------------------------------------------------------

model Invitation {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  /// Lowercased + trimmed at write time. Citext so lookups are
  /// case-insensitive without calling lower() at every query site.
  email            String    @db.Citext
  /// 'owner' | 'fleet_admin' | 'fleet_staff' | 'driver' | custom
  role             String
  /// SHA-256(token) base64url. Plaintext lives only in the email + URL.
  /// Unique so a pathological collision becomes a constraint violation
  /// instead of a silent account takeover (defence in depth at 256-bit).
  tokenHash        String    @unique
  /// Pre-existing Panorama User the admin is re-inviting; NULL when the
  /// target has no account yet.
  targetUserId     String?   @db.Uuid
  invitedByUserId  String    @db.Uuid
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?   @db.Uuid
  revokedAt        DateTime?
  revokedByUserId  String?   @db.Uuid
  /// Outbox state mirrored from the email delivery pipeline. See ADR-0008.
  /// `emailAttempts` counts worker attempts (covered by the ADR's
  /// "up to 5 attempts" retry policy — persisted here for observability
  /// and so retries survive worker restarts).
  emailQueuedAt    DateTime?
  emailSentAt      DateTime?
  emailBouncedAt   DateTime?
  emailAttempts    Int       @default(0)
  emailLastError   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy  User   @relation("InvitationInviter", fields: [invitedByUserId], references: [id])
  targetUser User?  @relation("InvitationTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  acceptedBy User?  @relation("InvitationAcceptor", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  revokedBy  User?  @relation("InvitationRevoker", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  /// A partial unique index enforces "at most one open invite per
  /// (tenantId, email)" — written as raw SQL in the migration because
  /// Prisma cannot model partial indexes.
  @@index([tenantId, email])
  @@index([expiresAt])
  @@map("invitations")
}

// -----------------------------------------------------------------------------
// Tenant-owned catalog primitives
// -----------------------------------------------------------------------------

model Category {
  id               String       @id @default(uuid()) @db.Uuid
  tenantId         String       @db.Uuid
  name             String
  kind             CategoryKind
  eula             String?
  checkoutAccepted Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  models              AssetModel[]
  inspectionTemplates InspectionTemplate[]

  @@unique([tenantId, name, kind])
  @@index([tenantId])
  @@map("categories")
}

enum CategoryKind {
  HARDWARE
  LICENSE
  ACCESSORY
  CONSUMABLE
  COMPONENT
  VEHICLE
  OTHER

  @@map("category_kind")
}

model Manufacturer {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  name         String
  url          String?
  supportEmail String?
  supportPhone String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  models AssetModel[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("manufacturers")
}

model AssetModel {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  categoryId     String   @db.Uuid
  manufacturerId String?  @db.Uuid
  name           String
  modelNumber    String?
  imageUrl       String?
  fieldsetId     String?  @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  manufacturer Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  assets       Asset[]

  @@index([tenantId])
  @@index([categoryId])
  @@map("asset_models")
}

// -----------------------------------------------------------------------------
// Asset — unified across hardware, vehicles, licenses, etc.
// -----------------------------------------------------------------------------

model Asset {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @db.Uuid
  modelId        String      @db.Uuid
  tag            String
  name           String
  serial         String?
  status         AssetStatus @default(READY)
  bookable       Boolean     @default(false)
  locationId     String?     @db.Uuid
  assignedUserId String?     @db.Uuid
  customFields   Json        @default("{}")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  archivedAt     DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  model        AssetModel    @relation(fields: [modelId], references: [id], onDelete: Restrict)
  reservations Reservation[]
  inspections  Inspection[]

  @@unique([tenantId, tag])
  @@index([tenantId, status])
  @@index([tenantId, bookable])
  @@map("assets")
}

enum AssetStatus {
  READY
  IN_USE
  RESERVED
  MAINTENANCE
  RETIRED

  @@map("asset_status")
}

// -----------------------------------------------------------------------------
// Reservations + approvals (from FleetManager)
// -----------------------------------------------------------------------------

model Reservation {
  id                 String                  @id @default(uuid()) @db.Uuid
  tenantId           String                  @db.Uuid
  assetId            String?                 @db.Uuid
  requesterUserId    String                  @db.Uuid
  onBehalfUserId     String?                 @db.Uuid
  startAt            DateTime
  endAt              DateTime
  purpose            String?
  approvalStatus     ApprovalStatus          @default(PENDING_APPROVAL)
  lifecycleStatus    ReservationStatus       @default(BOOKED)
  /// Basket grouping (ADR-0009 option B). When an admin creates several
  /// reservations at once (e.g. "3 trucks for this site visit") they
  /// share a basketId. Each row keeps its own lifecycle — approval,
  /// check-out, cancel are per-reservation. Basket is purely a
  /// creation-time + UX grouping primitive.
  basketId           String?                 @db.Uuid
  /// Approval trail — populated when an admin approves or rejects.
  approverUserId     String?                 @db.Uuid
  approvedAt         DateTime?
  approvalNote       String?
  /// Cancellation trail (applies whether requester or admin cancels).
  cancelReason       String?
  cancelledAt        DateTime?
  cancelledByUserId  String?                 @db.Uuid
  /// Check-out capture (ADR-0009 §Part B). `checkedOutAt` set when the
  /// operator releases the asset to the requester; the asset flips to
  /// IN_USE at the same time.
  checkedOutAt       DateTime?
  checkedOutByUserId String?                 @db.Uuid
  mileageOut         Int?
  conditionOut       String?
  /// Check-in capture. `damageFlag=true` routes the asset to MAINTENANCE
  /// rather than READY on return — requires ops attention before the
  /// asset becomes bookable again.
  checkedInAt        DateTime?
  checkedInByUserId  String?                 @db.Uuid
  mileageIn          Int?
  conditionIn        String?
  damageFlag         Boolean                 @default(false)
  damageNote         String?
  /// `tsrange('[startAt, endAt)')` — GENERATED ALWAYS STORED column
  /// that backs the `reservations_no_overlap` exclusion constraint
  /// (ADR-0009 §Alternatives, migration 0010). Read-only; set by
  /// Postgres. Prisma exposes it as Unsupported so client writes
  /// never touch it.
  bookingRange       Unsupported("tsrange")?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  asset        Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
  requester    User         @relation("ReservationRequester", fields: [requesterUserId], references: [id])
  onBehalf     User?        @relation("ReservationOnBehalf", fields: [onBehalfUserId], references: [id])
  approver     User?        @relation("ReservationApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  canceller    User?        @relation("ReservationCanceller", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  checkedOutBy User?        @relation("ReservationCheckedOutBy", fields: [checkedOutByUserId], references: [id], onDelete: SetNull)
  checkedInBy  User?        @relation("ReservationCheckedInBy", fields: [checkedInByUserId], references: [id], onDelete: SetNull)
  inspections  Inspection[]

  @@index([tenantId, startAt])
  @@index([tenantId, approvalStatus])
  @@index([tenantId, assetId])
  @@index([tenantId, requesterUserId])
  @@index([tenantId, lifecycleStatus])
  @@index([tenantId, basketId])
  @@map("reservations")
}

model BlackoutSlot {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  /// NULL = applies to all assets in the tenant (global maintenance
  /// window, holiday, etc.). Non-null = scoped to that asset.
  assetId         String?  @db.Uuid
  title           String
  startAt         DateTime
  endAt           DateTime
  reason          String?
  createdByUserId String   @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdByUserId], references: [id])

  @@index([tenantId, startAt])
  @@index([tenantId, assetId])
  @@map("blackout_slots")
}

enum ApprovalStatus {
  PENDING_APPROVAL
  AUTO_APPROVED
  APPROVED
  REJECTED

  @@map("approval_status")
}

enum ReservationStatus {
  BOOKED
  CHECKED_OUT
  RETURNED
  CANCELLED
  MISSED
  MAINTENANCE_REQUIRED
  REDIRECTED

  @@map("reservation_status")
}

// -----------------------------------------------------------------------------
// Audit log — hash-chained, append-only
// -----------------------------------------------------------------------------

model AuditEvent {
  id           BigInt   @id @default(autoincrement())
  tenantId     String?  @db.Uuid
  actorUserId  String?  @db.Uuid
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  occurredAt   DateTime @default(now())
  prevHash     Bytes?
  selfHash     Bytes

  @@index([tenantId, occurredAt(sort: Desc)])
  @@map("audit_events")
}

// -----------------------------------------------------------------------------
// System (global) — feature flags, cluster-level config
// -----------------------------------------------------------------------------

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

/// Tracks (source system, entity, source id) → Panorama UUID for migration
/// idempotency. Populated by @panorama/migrator's `migrate` command output
/// and consumed by the core-api's ImportService. Not tenant-scoped —
/// migrations are super-admin operations.
model ImportIdentityMap {
  id         BigInt   @id @default(autoincrement())
  source     String
  entity     String
  sourceId   String
  panoramaId String   @db.Uuid
  tenantId   String?  @db.Uuid
  createdAt  DateTime @default(now())

  @@unique([source, entity, sourceId])
  @@index([source, entity, panoramaId])
  @@map("import_identity_map")
}

// -----------------------------------------------------------------------------
// Personal Access Tokens (ADR-0010) — per-user, tenant-scoped Bearer
// tokens consumed by the Snipe-IT compatibility shim at /api/v1. Hashed
// at rest; plaintext is returned exactly once at creation.
// -----------------------------------------------------------------------------

model PersonalAccessToken {
  id                 String    @id @default(uuid()) @db.Uuid
  /// Token belongs to this user — authentication attribution runs as them.
  userId             String    @db.Uuid
  /// Tenant scope — cross-tenant access requires a different token.
  tenantId           String    @db.Uuid
  /// Who minted the token. Usually equals userId; differs when a
  /// super-admin mints on behalf of a user (bulk onboarding flow).
  issuerUserId       String    @db.Uuid
  /// Human-readable label shown in the admin UI ("fleet-cluster-prod").
  name               String
  /// sha256(plaintext) base64url-encoded. Plaintext is returned to the
  /// caller once at creation and never persisted. Same pattern as
  /// Invitation.tokenHash (ADR-0008).
  tokenHash          String    @unique
  /// Literal "pnrm_pat_" + first 8 chars of the base64url secret —
  /// deterministic, non-secret prefix used for UI display without
  /// plaintext access. 48 bits of prefix disclosure leaves 208 bits of
  /// remaining entropy. See ADR-0010.
  tokenPrefix        String
  /// Scope list — endpoints under SnipeitCompatModule require
  /// 'snipeit.compat.read' at 0.2. Future scopes are additive.
  scopes             String[]
  /// null = no expiration. UI defaults to now() + 1y.
  expiresAt          DateTime?
  /// Synchronous-first-use, async-batched afterwards. Source-of-truth
  /// for security is rate-limiter metrics, not this column.
  lastUsedAt         DateTime?
  /// Soft revocation — middleware filters tokens where revokedAt IS NOT NULL.
  /// A DB trigger emits `panorama.pat.resurrected` if this column ever
  /// transitions non-NULL → NULL (tamper detection for direct SQL edits).
  revokedAt          DateTime?
  createdAt          DateTime  @default(now())
  /// Audit-of-creation context. Not PII — IP + UA are already in the
  /// session event metadata.
  createdByIp        String?
  createdByUserAgent String?

  user   User   @relation("OwnedTokens", fields: [userId], references: [id], onDelete: Cascade)
  issuer User   @relation("IssuedTokens", fields: [issuerUserId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([tenantId, revokedAt])
  @@index([userId, revokedAt])
  @@map("personal_access_tokens")
}

// -----------------------------------------------------------------------------
// Notification event bus outbox (ADR-0011) — domain services INSERT
// inside the same transaction as their domain write; NotificationDispatcher
// polls and fans out to ChannelRegistry-registered handlers.
// -----------------------------------------------------------------------------

model NotificationEvent {
  id               String                  @id @default(uuid()) @db.Uuid
  /// Null = cluster-wide event. Most events are tenant-scoped.
  tenantId         String?                 @db.Uuid
  /// Registered in NOTIFICATION_PAYLOAD_SCHEMAS. Unknown types are
  /// rejected at enqueueWithin time (ADR-0011).
  eventType        String
  /// Zod-validated + redaction-swept at enqueue. Never contains
  /// plaintext tokens / passwords / secrets. CHECK constraint caps
  /// pg_column_size(payload) <= 16384 (see migration 0011).
  payload          Json
  status           NotificationEventStatus @default(PENDING)
  dispatchAttempts Int                     @default(0)
  availableAt      DateTime                @default(now())
  lastAttemptAt    DateTime?
  lastError        String?
  /// Durable per-row retry log. Queryable without joining a second
  /// table. `lastError` is the fast-path convenience.
  errorHistory     Json                    @default("[]")
  /// `{ "email": "dispatched", "slack": "failed", … }` — per-channel
  /// outcome so a "DEAD" event can still show that the email channel
  /// succeeded.
  channelResults   Json                    @default("{}")
  /// Scoped to (tenantId, eventType, dedupKey) via a hand-written
  /// partial unique index in migration 0011 (Prisma 5.x can't model
  /// partial uniques).
  dedupKey         String?
  dispatchedAt     DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@index([tenantId, eventType, createdAt(sort: Desc)])
  @@map("notification_events")
}

enum NotificationEventStatus {
  PENDING
  IN_PROGRESS
  DISPATCHED
  FAILED
  DEAD

  @@map("notification_event_status")
}

// -----------------------------------------------------------------------------
// Inspections + photo evidence (ADR-0012)
//
//   * Templates are tenant-authored checklists bound to a CategoryKind OR a
//     specific Category (XOR, enforced by CHECK constraint).
//   * An Inspection snapshots the template shape at start time into
//     templateSnapshot Json so subsequent edits to the template don't
//     corrupt historical responses. A BEFORE UPDATE trigger rejects any
//     change to templateSnapshot unless panorama.allow_snapshot_edit is
//     set in the transaction (super-admin break-glass).
//   * Photos live under S3 key `tenants/{tenantId}/inspections/{inspId}/photos/{photoId}.jpg`
//     enforced by a UUID-strict regex CHECK. sharp sanitises + re-encodes
//     to JPEG; EXIF / ICC / XMP are explicitly stripped (keepExif/ICC/Metadata(false)).
//     `capturedAt` preserves EXIF DateTimeOriginal BEFORE strip for insurance
//     defensibility; GPS + owner fields are dropped.
//   * Tenant isolation: RLS + FORCE RLS + mandated runInTenant.
// -----------------------------------------------------------------------------

model InspectionTemplate {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @db.Uuid
  name            String
  description     String?
  /// Scope: categoryKind (all assets of that kind) OR categoryId
  /// (specific override). Exactly one set, enforced by CHECK constraint.
  /// `categoryKind` is a deliberate denormalisation — a sentinel meaning
  /// "any Category in this tenant with kind=X". No FK by design; renaming
  /// a category.kind would be a breaking schema change regardless.
  /// Launcher resolution: categoryId beats categoryKind when both match.
  categoryKind    CategoryKind?
  categoryId      String?       @db.Uuid
  displayOrder    Int           @default(0)
  archivedAt      DateTime?
  createdByUserId String        @db.Uuid
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy   User                     @relation("InspectionTemplateCreator", fields: [createdByUserId], references: [id])
  items       InspectionTemplateItem[]
  inspections Inspection[]

  // Partial composite indexes for the launcher queries are hand-written
  // in migration.sql (Prisma can't model partial indexes).
  @@map("inspection_templates")
}

model InspectionTemplateItem {
  id            String             @id @default(uuid()) @db.Uuid
  templateId    String             @db.Uuid
  tenantId      String             @db.Uuid
  position      Int
  label         String
  itemType      InspectionItemType
  required      Boolean            @default(false)
  /// If true AND itemType != PHOTO, the item carries BOTH an answer
  /// AND must have at least one photo attached.
  photoRequired Boolean            @default(false)
  minValue      Float?
  maxValue      Float?
  helpText      String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, position])
  @@map("inspection_template_items")
}

enum InspectionItemType {
  BOOLEAN
  TEXT
  NUMBER
  PHOTO

  @@map("inspection_item_type")
}

model Inspection {
  id                String             @id @default(uuid()) @db.Uuid
  tenantId          String             @db.Uuid
  /// SetNull — if an operator hard-deletes a template (rare), the
  /// inspection preserves its own snapshot and keeps working.
  templateId        String?            @db.Uuid
  /// Immutable snapshot of the template at start time — enforces
  /// response integrity across template edits. Shape validated by
  /// Zod at write time; 64 kB cap enforced by CHECK constraint.
  /// `BEFORE UPDATE` trigger rejects column change unless the
  /// panorama.allow_snapshot_edit GUC is set in the transaction.
  templateSnapshot  Json
  /// Restrict — hard-deleting an asset with inspection history is
  /// blocked. Archive the asset instead.
  assetId           String             @db.Uuid
  /// Optional link to the reservation that triggered this inspection
  /// (pre-trip / post-trip). Reservation.checkOut reads this column
  /// plus inspections table directly (no InspectionService import —
  /// see ADR-0012 §8).
  reservationId     String?            @db.Uuid
  /// Restrict — a user with inspection history blocks hard-delete.
  /// Soft-delete via User.deletedAt is the normal pathway.
  startedByUserId   String             @db.Uuid
  status            InspectionStatus   @default(IN_PROGRESS)
  outcome           InspectionOutcome?
  summaryNote       String?
  startedAt         DateTime           @default(now())
  completedAt       DateTime?
  completedByUserId String?            @db.Uuid
  /// Review writes MUST be conditional on `reviewedAt IS NULL` at
  /// the service layer to prevent the double-approval bug.
  /// `reviewNote` is appendable post-review (body-shop follow-up
  /// workflow); updates emit panorama.inspection.review_note_updated.
  reviewedAt        DateTime?
  reviewedByUserId  String?            @db.Uuid
  reviewNote        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template    InspectionTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  asset       Asset                @relation(fields: [assetId], references: [id], onDelete: Restrict)
  reservation Reservation?         @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  startedBy   User                 @relation("InspectionStarter", fields: [startedByUserId], references: [id], onDelete: Restrict)
  completedBy User?                @relation("InspectionCompleter", fields: [completedByUserId], references: [id], onDelete: SetNull)
  reviewedBy  User?                @relation("InspectionReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  responses   InspectionResponse[]
  photos      InspectionPhoto[]

  @@map("inspections")
}

enum InspectionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("inspection_status")
}

enum InspectionOutcome {
  PASS
  FAIL
  NEEDS_MAINTENANCE

  @@map("inspection_outcome")
}

model InspectionResponse {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  inspectionId   String   @db.Uuid
  /// References an `id` inside the parent inspection's
  /// templateSnapshot. No FK — integrity enforced by trigger
  /// validate_inspection_response_snapshot_ref (SECURITY DEFINER
  /// so break-glass transactions don't hit false-negatives).
  snapshotItemId String   @db.Uuid
  /// At most one of these three populated (single-answer CHECK).
  /// PHOTO-type items carry their answer in InspectionPhoto rows.
  booleanValue   Boolean?
  textValue      String?
  numberValue    Float?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inspection Inspection        @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  photos     InspectionPhoto[]

  @@unique([inspectionId, snapshotItemId])
  @@map("inspection_responses")
}

model InspectionPhoto {
  /// Server-minted UUID; never an idempotency handle — that's
  /// clientUploadKey (below). Split prevents the existence-oracle
  /// that would arise from treating PK-collisions as "already done".
  id               String                @id @default(uuid()) @db.Uuid
  tenantId         String                @db.Uuid
  inspectionId     String                @db.Uuid
  responseId       String?               @db.Uuid
  /// Client-generated UUID used strictly as the retry dedup key.
  /// Unique scoped to inspectionId (@@unique below) so a 23505 on
  /// retry guarantees same-owner, same-inspection match. Service
  /// layer re-checks uploadedByUserId on 23505 to close the
  /// existence-oracle corner case where a different user supplies
  /// the same UUID.
  clientUploadKey  String                @db.Uuid
  /// Format: `tenants/{tenantId}/inspections/{inspectionId}/photos/{photoId}.jpg`.
  /// UUID-strict CHECK constraint + LIKE tenantId prefix.
  storageKey       String
  /// Always "image/jpeg" in 0.3 — sanitise re-encodes everything.
  contentType      String
  sizeBytes        Int
  /// SHA-256 of the SANITISED bytes (post-EXIF-strip + re-encode).
  sha256           String
  width            Int
  height           Int
  /// Extracted from EXIF DateTimeOriginal BEFORE strip. User-supplied,
  /// phones lie, but strictly more credible than uploadedAt for an
  /// insurance hearing. exifr parse wrapped in try/catch; malformed
  /// EXIF writes null.
  capturedAt       DateTime?
  /// FIELD NAMES found and stripped. Values NEVER persisted.
  /// Examples: ["GPSLatitude", "GPSLongitude", "Make", "Model",
  /// "ICC_Profile", "XMP:Creator"].
  exifStripped     Json                  @default("[]")
  status           InspectionPhotoStatus @default(UPLOADED)
  uploadedByUserId String                @db.Uuid
  uploadedAt       DateTime              @default(now())
  /// Soft-delete. Retention sweep (§10) hard-deletes after
  /// Tenant.inspectionPhotoRetentionDays (default 425). GDPR Art. 17
  /// uses the super-admin break-glass path, not the sweep.
  deletedAt        DateTime?

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inspection Inspection          @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  response   InspectionResponse? @relation(fields: [responseId], references: [id], onDelete: SetNull)
  uploadedBy User                @relation("InspectionPhotoUploader", fields: [uploadedByUserId], references: [id])

  @@unique([inspectionId, clientUploadKey])
  @@map("inspection_photos")
}

enum InspectionPhotoStatus {
  UPLOADED
  REJECTED

  @@map("inspection_photo_status")
}
