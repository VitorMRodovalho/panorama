# Panorama core-api example env.
# Copy to .env and edit for local dev. Never commit secrets.

# --- Runtime ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# --- Database (Postgres 16) ---
DATABASE_URL=postgres://panorama:panorama@localhost:5432/panorama?schema=public
# Separate, least-privilege role used by the application at runtime.
# RLS relies on this role NOT having BYPASSRLS.
DATABASE_APP_ROLE=panorama_app
DATABASE_APP_PASSWORD=panorama

# --- Cache / queues (Redis 7) ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (S3-compatible; MinIO in dev; ADR-0012) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_PHOTOS=panorama-photos
S3_BUCKET_BACKUPS=panorama-backups
S3_FORCE_PATH_STYLE=true
# Presigned-GET TTL for photo reads. 300s = detail view; list-page
# thumbnails override to 60s in code.
S3_SIGNED_URL_TTL_SECONDS=300
# Dev-only escape hatch — allows `S3_ENDPOINT` to resolve to a
# private IP (RFC1918, loopback) so the MinIO container works. In
# production MUST be unset (or false) — the bootstrap check rejects
# any endpoint that resolves to private/metadata addresses.
S3_ALLOW_PRIVATE_ENDPOINT=true

# --- Feature flags ---
# Inspections module (ADR-0012). Default false for first releases;
# flip to true per-tenant on canary. Community default flips to true
# after two stable patch releases.
FEATURE_INSPECTIONS=false

# --- Session / crypto ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=replace-me-with-32-random-bytes-in-base64url
SESSION_COOKIE_NAME=panorama_session

# --- OIDC / OAuth2 providers (optional at dev time) ---
OIDC_GOOGLE_CLIENT_ID=
OIDC_GOOGLE_CLIENT_SECRET=
OIDC_MICROSOFT_CLIENT_ID=
OIDC_MICROSOFT_CLIENT_SECRET=
OIDC_MICROSOFT_TENANT=

# --- SMTP ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=panorama@example.com
SMTP_EHLO_HOST=panorama.local

# --- Event bus ---
# Set to empty to run events in-process (single-node dev).
NATS_URL=

# --- i18n ---
I18N_DEFAULT_LOCALE=en
I18N_ENABLED_LOCALES=en,pt-br,es

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=panorama-core-api
PROM_METRICS_PORT=9090

# --- Safety rails for dev ---
# Panic if the seed routine is about to run against a production-looking URL.
ALLOW_DESTRUCTIVE_SEED=false
