# Panorama — root .env.example.
#
# This file consolidates every env var the Compose stack
# (`infra/docker/compose.prod.yml`) and the production deploy targets
# (`Dockerfile`) read at runtime. Self-hosters: copy this to `.env` at
# the repo root and edit the marked-`REQUIRED` values before
# `docker compose up`.
#
# Per-app `.env.example` files (`apps/core-api/.env.example`,
# `apps/web/.env.example`) remain authoritative for in-repo dev
# (`pnpm dev`). This root file is the deploy / Compose surface.
#
# Anything marked REQUIRED has no safe default and the Compose stack
# will refuse to start without it.

# ===========================================================================
# Runtime
# ===========================================================================
NODE_ENV=production
LOG_LEVEL=info
PORT=4000
PANORAMA_IMAGE_TAG=latest

# ===========================================================================
# Database — Postgres
# ===========================================================================
# REQUIRED: app-role connection. NOBYPASSRLS in production. Per ADR-0015
# the privileged connection (DATABASE_PRIVILEGED_URL below) is a separate
# string and MUST point at a different role. If both are set to the same
# URL, the runtime aborts at boot with a configuration error.
POSTGRES_DB=panorama
POSTGRES_USER=panorama
POSTGRES_PASSWORD=replace-me-with-a-strong-password
DATABASE_URL=postgres://panorama_app:replace-me@postgres:5432/panorama?schema=public&sslmode=require

# ADR-0015 — privileged client. Self-hosted: connects as
# `panorama_super_admin` (BYPASSRLS, role created by 0001 rls.sql).
# Supabase: connects as the `postgres` user (BYPASSRLS by virtue of
# being DB owner). NEVER as Supabase's service_role JWT — that's
# account-root and forbidden in app code per security-reviewer.
DATABASE_PRIVILEGED_URL=postgres://panorama_super_admin:replace-me@postgres:5432/panorama?schema=public&sslmode=require

# ===========================================================================
# Cache + queue — Redis
# ===========================================================================
# REQUIRED. BullMQ + sliding-window rate-limiter. Single-node OK at 0.3.
REDIS_URL=redis://redis:6379/0

# ===========================================================================
# Object storage — S3-compatible
# ===========================================================================
# Compose default = MinIO sidecar. For Cloudflare R2:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_FORCE_PATH_STYLE=false
# For AWS S3:
#   leave S3_ENDPOINT unset; S3_REGION=us-east-1 (or your region);
#   S3_FORCE_PATH_STYLE=false.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET_PHOTOS=panorama-photos
S3_ACCESS_KEY=replace-me-minio-access-key
S3_SECRET_KEY=replace-me-minio-secret-key
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=300
# Dev / Compose-on-localhost only. The bootstrap SSRF guard will refuse
# to resolve S3_ENDPOINT to a private IP unless this is true. Production
# external-bucket deployments leave this `false` and the guard rejects
# RFC1918 / metadata addresses.
S3_ALLOW_PRIVATE_ENDPOINT=true

# ===========================================================================
# Feature flags
# ===========================================================================
# Inspections (ADR-0012). Default false; flip per-tenant on canary.
FEATURE_INSPECTIONS=false
# SnipeIT compat shim (ADR-0010). Default true; turn off if no Snipe-IT
# clients consume /api/v1.
FEATURE_SNIPEIT_COMPAT_SHIM=true

# ===========================================================================
# Sessions
# ===========================================================================
# REQUIRED. Generate via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Rotation invalidates ALL active sessions — expected, document the playbook.
SESSION_SECRET=replace-me-with-32-random-bytes-base64url
SESSION_COOKIE_NAME=panorama_session

# ===========================================================================
# CSRF Origin allowlist (SEC-02 / #34)
# ===========================================================================
# Comma-separated list of trusted scheme://host origins. State-changing
# requests (POST/PUT/PATCH/DELETE) with an `Origin` header must match one
# of these or the auth `APP_BASE_URL`. Server-to-server fetches that omit
# `Origin` are allowed (they cannot impersonate users without the HttpOnly
# session cookie).
#
# Examples:
#   single deployment behind a proxy: WEB_ORIGIN=https://panorama.example.com
#   web on a different host:          WEB_ORIGIN=https://panorama.example.com,https://staging.example.com
WEB_ORIGIN=http://localhost:3000

# ===========================================================================
# OIDC providers (optional; password auth still works without these)
# ===========================================================================
OIDC_GOOGLE_CLIENT_ID=
OIDC_GOOGLE_CLIENT_SECRET=
# Google Workspace `hd` (hosted domain) values, comma-separated, that we
# trust to stand in for the per-account `email_verified` claim.
# Workspace admins prove domain ownership out-of-band, so an `hd` claim
# from Google is itself the verification signal.
# Leave empty for strict mode: any login with `email_verified !== true`
# is refused. Microsoft has no equivalent claim — Entra deployments must
# enforce email verification on the IdP side.
# Example: OIDC_GOOGLE_TRUSTED_HD_DOMAINS=acme.com,beta.example
OIDC_GOOGLE_TRUSTED_HD_DOMAINS=
OIDC_MICROSOFT_CLIENT_ID=
OIDC_MICROSOFT_CLIENT_SECRET=
OIDC_MICROSOFT_TENANT=

# ===========================================================================
# SMTP — invitation + notification email
# ===========================================================================
# Compose dev default points at MailHog (port 1025). Production: a real
# relay (Postmark, SES, SendGrid, your own Postfix). SMTP_FROM must be a
# verified sender with the relay.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=panorama@example.com
SMTP_EHLO_HOST=panorama.example.com

# ===========================================================================
# i18n
# ===========================================================================
I18N_DEFAULT_LOCALE=en
I18N_ENABLED_LOCALES=en,pt-br,es

# ===========================================================================
# Web app
# ===========================================================================
# How the web app reaches the API. Inside Compose: http://core-api:4000.
# Behind a reverse proxy: the public URL the browser uses (the web app
# also forwards the user's session cookie to this URL on SSR).
CORE_API_URL=http://core-api:4000
PANORAMA_WEB_BASE_URL=http://localhost:3000

# ===========================================================================
# Observability (optional, all default off)
# ===========================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=panorama-core-api
PROM_METRICS_PORT=9090
