{
  "name": "@panorama/migrator",
  "version": "0.0.0",
  "private": true,
  "description": "CLI that reads Snipe-IT (API) + SnipeScheduler-FleetManager (MySQL dump) and produces Panorama fixtures.",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "bin": {
    "panorama-migrate": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/cli.ts",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@panorama/shared": "workspace:*",
    "commander": "^14.0.3",
    "pino": "^10.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}